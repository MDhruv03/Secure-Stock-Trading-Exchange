# Custom Snort Rules for Secure Trading Exchange

# 1. SQL Injection Detection
# This rule detects common SQL injection patterns in the request body.
alert tcp any any -> any 8000 (msg:"SQL Injection Attempt"; flow:to_server,established; content:"OR 1=1"; http_client_body; sid:1000001; rev:1;)

# 2. Replay Attack Detection
# This rule detects more than 3 requests to /order from the same IP in 10 seconds.
alert tcp any any -> any 8000 (msg:"Potential Replay Attack"; flow:to_server,established; content:"POST /order"; http_method; threshold:type limit, track by_src, count 3, seconds 10; sid:1000002; rev:1;)

# 3. Brute-Force Attack Detection
# This rule detects more than 5 requests to /token from the same IP in 10 seconds.
alert tcp any any -> any 8000 (msg:"Potential Brute-Force Attack"; flow:to_server,established; content:"POST /token"; http_method; threshold:type limit, track by_src, count 5, seconds 10; sid:1000003; rev:1;)